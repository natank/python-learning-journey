{
  "name": "cafe-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cafe-api/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "source venv/bin/activate && python src/main.py",
        "cwd": "apps/cafe-api"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3.13 -m venv venv && source venv/bin/activate && pip install -r requirements.txt",
        "cwd": "apps/cafe-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "source venv/bin/activate && pytest",
        "cwd": "apps/cafe-api"
      }
    }
  }
}
